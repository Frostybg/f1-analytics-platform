<!-- ===================== HERO ===================== -->
<section class="f1-race-hero-section">
  <div class="container-fluid px-3 px-lg-4">
    <a href="/calendar" class="f1-btn-back mt-3 d-inline-flex">
      <span aria-hidden="true">&larr;</span> Back to Calendar
    </a>
    <div class="py-4 py-lg-5">
      <span class="f1-eyebrow">
        <%= [meeting.countryName, meeting.location].filter(Boolean).join(' · ') %>
        <% if (dateRangeLabel) { %> &middot; <%= dateRangeLabel %><% } %>
      </span>
      <h1 class="f1-hero-title mt-2"><%= meeting.meetingName %></h1>
    </div>
  </div>
</section>

<div class="container-fluid px-3 px-lg-4 py-4">

  <!-- ============= WEEKEND SCHEDULE ============= -->
  <section aria-label="Weekend schedule" class="mb-4">
    <div class="f1-card">
      <div class="f1-card-header">
        <h2 class="f1-card-title mb-0">Weekend Schedule</h2>
        <p class="f1-card-subtitle mb-0" id="scheduleTimezoneLabel">All times in UTC</p>
      </div>
      <div class="f1-card-body p-0">
        <ul class="f1-schedule-list">
          <% sessions.forEach(function(s) { %>
            <li class="f1-schedule-row<%= s.isCompleted ? ' is-completed' : '' %>"
                data-datetime="<%= s.dateStart || '' %>">
              <span class="f1-schedule-name"><%= s.sessionName %></span>
              <span class="f1-schedule-datetime">
                <% if (s.dateStart) { %>
                  <%
                    const d = new Date(s.dateStart);
                    const day = d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
                    const time = d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' });
                  %>
                  <span class="f1-schedule-day"><%= day %></span>
                  <span class="f1-schedule-time"><%= time %></span>
                <% } else { %>
                  <span class="text-secondary">TBC</span>
                <% } %>
              </span>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============= RESULTS CENTER ============= -->
  <section aria-label="Session results" class="mb-4">
    <div class="f1-card">
      <div class="f1-card-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h2 class="f1-card-title mb-0">Results</h2>
          <p class="f1-card-subtitle mb-0">Select a session to view results</p>
        </div>
        <select id="sessionSelect" class="f1-session-select" aria-label="Select session">
          <% sessions.forEach(function(s) { %>
            <option
              value="<%= s.sessionKey %>"
              data-type="<%= s.sessionType %>"
              <%= (defaultSession && s.sessionKey === defaultSession.sessionKey) ? 'selected' : '' %>
            ><%= s.sessionName %></option>
          <% }); %>
        </select>
      </div>
      <div class="f1-card-body p-0" id="resultsOuter">
        <div id="resultsLoading" class="f1-state" hidden>
          <div class="spinner-border f1-spinner" role="status">
            <span class="visually-hidden">Loading…</span>
          </div>
          <p class="mt-3 text-secondary small">Loading results…</p>
        </div>
        <div id="resultsError" class="f1-state" hidden>
          <div class="f1-state-icon f1-state-icon--error">!</div>
          <p class="mt-3 text-secondary" id="resultsErrorMsg">Unable to load results.</p>
        </div>
        <div id="resultsEmpty" class="f1-state" hidden>
          <div class="f1-state-icon">—</div>
          <p class="mt-3 text-secondary">No results available for this session yet.</p>
        </div>
        <div id="resultsTable" hidden>
          <div class="table-responsive">
            <table class="f1-results-table">
              <thead id="resultsHead"></thead>
              <tbody id="resultsBody"></tbody>
            </table>
          </div>
          <div id="resultsToggleRow" class="f1-results-toggle-row" hidden>
            <button type="button" id="resultsToggleBtn" class="f1-results-toggle-btn">
              Show All <span class="f1-toggle-arrow">&#9660;</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============= STANDINGS NAVIGATION ============= -->
  <div class="d-flex justify-content-end mb-4">
    <a href="/standings" class="btn btn-f1-outline">View Full Standings &rarr;</a>
  </div>

  <!-- ============= CIRCUIT INFORMATION ============= -->
  <section aria-label="Circuit information" class="mb-4">
    <div class="f1-card">
      <div class="f1-card-header">
        <h2 class="f1-card-title mb-0">Circuit</h2>
      </div>
      <div class="f1-circuit-section">

        <!-- SVG map (left ~42%) -->
        <% if (circuitInfo && circuitInfo.svgFile) { %>
          <div class="f1-circuit-map">
            <img
              src="/img/circuits/<%= circuitInfo.svgFile %>"
              alt="<%= (circuitInfo.circuitName || meeting.circuitShortName || meeting.meetingName) + ' circuit layout' %>"
              class="f1-circuit-img"
            />
          </div>
        <% } %>

        <!-- Details (right ~58%) -->
        <div class="f1-circuit-details<%= !(circuitInfo && circuitInfo.svgFile) ? ' f1-circuit-details--full' : '' %>">
          <dl class="f1-circuit-dl">
            <div class="f1-circuit-dl-row">
              <dt>Circuit</dt>
              <dd><%= (circuitInfo && circuitInfo.circuitName) || meeting.circuitShortName || '—' %></dd>
            </div>
            <div class="f1-circuit-dl-row">
              <dt>Country</dt>
              <dd><%= (circuitInfo && circuitInfo.country) || meeting.countryName || '—' %></dd>
            </div>
            <div class="f1-circuit-dl-row">
              <dt>Location</dt>
              <dd><%= (circuitInfo && circuitInfo.city) || meeting.location || '—' %></dd>
            </div>
            <% if (roundNumber) { %>
              <div class="f1-circuit-dl-row">
                <dt>Round</dt>
                <dd>Round <%= roundNumber %> of <%= meeting.year %></dd>
              </div>
            <% } %>
            <% if (dateRangeLabel) { %>
              <div class="f1-circuit-dl-row">
                <dt>Race Weekend</dt>
                <dd><%= dateRangeLabel %></dd>
              </div>
            <% } %>
          </dl>
        </div>

      </div><!-- /f1-circuit-section -->
    </div>
  </section>

</div>

<!-- Seed server-side data for client JS -->
<script>
  window.F1_RACE = {
    meetingKey: <%- meeting.meetingKey %>,
    defaultSessionKey: <%- defaultSession ? defaultSession.sessionKey : 'null' %>,
    gmtOffset: <%- JSON.stringify(gmtOffset) %>,
    sessions: <%- JSON.stringify(sessions.map(function(s) {
      return { sessionKey: s.sessionKey, sessionName: s.sessionName, sessionType: s.sessionType, dateStart: s.dateStart };
    })) %>,
    initialResults: <%- JSON.stringify(initialResults) %>
  };
</script>
<script src="/js/pages/race-details.js"></script>
