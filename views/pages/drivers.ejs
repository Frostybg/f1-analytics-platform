<!-- ===================== PAGE HEADER ===================== -->
<section class="f1-page-header">
  <div class="container-fluid px-3 px-lg-4 py-4">
    <span class="f1-eyebrow">2024 Season</span>
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-2 mt-1">
      <div>
        <h1 class="f1-hero-title fs-1 mb-0">Drivers</h1>
        <p class="text-secondary mb-0">The current Formula 1 grid, powered by the OpenF1 API.</p>
      </div>
      <span class="f1-pill" id="driversCount" hidden></span>
    </div>
  </div>
</section>

<div class="container-fluid px-3 px-lg-4 py-4">
  <!-- ===================== LOADING STATE ===================== -->
  <div id="driversLoading" class="f1-state">
    <div class="spinner-border f1-spinner" role="status" aria-hidden="true"></div>
    <p class="mt-3 mb-0 text-secondary">Loading drivers…</p>
  </div>

  <!-- ===================== ERROR STATE ===================== -->
  <div id="driversError" class="f1-state" hidden>
    <div class="f1-state-icon f1-state-icon--error" aria-hidden="true">!</div>
    <h2 class="h5 mt-3 mb-1">Couldn’t load drivers</h2>
    <p class="text-secondary mb-3" id="driversErrorMsg">Something went wrong.</p>
    <button type="button" class="btn btn-f1-primary" id="driversRetry">Try again</button>
  </div>

  <!-- ===================== EMPTY STATE ===================== -->
  <div id="driversEmpty" class="f1-state" hidden>
    <div class="f1-state-icon" aria-hidden="true">∅</div>
    <h2 class="h5 mt-3 mb-1">No drivers found</h2>
    <p class="text-secondary mb-0">There is no driver data available right now.</p>
  </div>

  <!-- ===================== DRIVERS GRID ===================== -->
  <div id="driversGrid" class="row g-3 g-lg-4" hidden></div>
</div>

<!-- Page-specific script (extracted by express-ejs-layouts, runs after libs) -->
<script src="/js/pages/drivers.js"></script>
