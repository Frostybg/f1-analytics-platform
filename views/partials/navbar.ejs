<%
  // Single source of truth for the main navigation. Future pages just need a
  // new entry here (and a matching route) to appear in the navbar.
  const navItems = [
    { key: 'home',       label: 'Dashboard',  href: '/' },
    { key: 'drivers',    label: 'Drivers',    href: '/drivers' },
    { key: 'standings',  label: 'Standings',  href: '/standings' },
    { key: 'calendar',   label: 'Calendar',   href: '/calendar' },
    { key: 'telemetry',  label: 'Telemetry',  href: '/telemetry' },
    { key: 'compare',    label: 'Compare',    href: '/compare' },
    { key: 'circuits',   label: 'Circuits',   href: '/circuits' },
    { key: 'about',      label: 'About',      href: '/about' },
  ];
%>
<nav class="navbar navbar-expand-lg f1-navbar sticky-top">
  <div class="container-fluid px-3 px-lg-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <span class="f1-brand-mark" aria-hidden="true"></span>
      <span class="f1-brand-text">F1 <span class="f1-brand-accent">Analytics</span></span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <% navItems.forEach(function (item) { %>
          <li class="nav-item">
            <a
              class="nav-link <%= active === item.key ? 'active' : '' %>"
              <%= active === item.key ? 'aria-current="page"' : '' %>
              href="<%= item.href %>"
            ><%= item.label %></a>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</nav>
