# ----------------------------------------------------------------------------
# Formula 1 Analytics Platform - Environment Variables
# Copy this file to ".env" and adjust the values for your environment.
# ----------------------------------------------------------------------------

# Port the Express server listens on
PORT=3000

# Application environment: development | production
NODE_ENV=development

# Base URL of the OpenF1 API (no trailing slash)
OPENF1_API_BASE_URL=https://api.openf1.org/v1

# Timeout (in milliseconds) for outgoing OpenF1 API requests
OPENF1_API_TIMEOUT=10000
